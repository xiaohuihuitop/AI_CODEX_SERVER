{
  "name": "codex-windows-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "description": "Windows local bridge for phone-to-Codex Desktop control",
  "scripts": {
    "start": "node desktop-client/server.js",
    "start:cloud": "node server/cloud-server.js",
    "start:agent": "node desktop-client/desktop-agent.js",
    "start:manager": "node desktop-client/desktop-manager-server.js",
    "start:manager:gui": "electron desktop-client/electron/main.js",
    "start:manager:gui:legacy": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File desktop-client/scripts/codex-desktop-manager-gui.ps1",
    "check": "node -e \"const fs=require('fs');const cp=require('child_process');const list=d=>fs.existsSync(d)?fs.readdirSync(d).filter(f=>f.endsWith('.js')).map(f=>d+'/'+f):[];const files=['server/cloud-server.js','desktop-client/server.js','desktop-client/desktop-agent.js','desktop-client/desktop-manager-server.js',...list('server/src'),...list('desktop-client/src'),...list('desktop-client/electron')];for(const file of files)cp.execFileSync(process.execPath,['--check',file],{stdio:'inherit'});\"",
    "test": "node --test",
    "build:manager:win": "electron-builder --win dir --projectDir desktop-client"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2"
  }
}
