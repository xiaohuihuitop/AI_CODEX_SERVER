{
  "name": "codex-windows-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "description": "Windows local bridge for phone-to-Codex Desktop control",
  "scripts": {
    "start": "node server.js",
    "start:cloud": "node cloud-server.js",
    "start:agent": "node desktop-agent.js",
    "start:manager": "node desktop-manager-server.js",
    "check": "node -e \"const fs=require('fs');const cp=require('child_process');const files=['server.js','cloud-server.js','desktop-agent.js','desktop-manager-server.js',...fs.readdirSync('src').filter(f=>f.endsWith('.js')).map(f=>'src/'+f)];for(const file of files)cp.execFileSync(process.execPath,['--check',file],{stdio:'inherit'});\"",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ws": "^8.21.0"
  }
}
